<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Document Received — Citizen Link</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f6f9; font-family:'Inter', Arial, sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- Header -->
          <tr>
            <td align="center" style="background-color:#003b5a; border-radius:12px 12px 0 0; padding:28px 40px;">
              <!-- Logo -->
              <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto 14px;"><tr><td width="52" height="52" align="center" valign="middle" style="background-color:#006397;border-radius:10px;width:52px;height:52px;line-height:0;"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 30 30"><path d="M15 1 L27 5.5 L27 16 Q27 24 15 28 Q3 24 3 16 L3 5.5 Z" fill="#e8b84b"/><path d="M10 15 L13 18 L20 10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg></td></tr></table>
              <p style="margin:0; font-size:22px; font-weight:700; color:#ffffff; letter-spacing:-0.3px;">Citizen Link</p>
              <p style="margin:6px 0 0;font-size:13px;color:#a8c8da;font-style:italic;">Where integrity becomes impact and income.</p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color:#ffffff; padding:40px; border-left:1px solid #e2e8f0; border-right:1px solid #e2e8f0;">

              <!-- Success badge -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 24px;">
                <tr>
                  <td style="background-color:#dcfce7; border-radius:8px; padding:10px 18px;">
                    <p style="margin:0; font-size:13px; font-weight:700; color:#15803d;">✔ Document Successfully Delivered</p>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 20px; font-size:22px; font-weight:700; color:#003b5a; line-height:1.3;">
                Your Document Has Been Received
              </p>
              <p style="margin:0 0 28px; font-size:15px; color:#475569; line-height:1.7;">
                You have confirmed receipt of your <strong>{{exchange.document.type.name}}</strong>
                (claim <strong>#{{exchange.claim.claimNumber}}</strong>). Your case is now complete.
                Thank you for using Citizen Link to reunite with your document.
              </p>

              <!-- CTA -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 32px;">
                <tr>
                  <td align="center" style="border-radius:8px; background-color:#1d9e75;">
                    <a href="citizenlinkapp://document-case/{{exchange.claim.id}}"
                      style="display:inline-block; padding:14px 32px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px;">
                      View Completed Case →
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:0; font-size:14px; color:#475569; line-height:1.7;">
                Thank you for doing the right thing.<br />
                <strong style="color:#003b5a;">The Citizen Link Team</strong>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8fafc; border:1px solid #e2e8f0; border-top:none; border-radius:0 0 12px 12px; padding:20px 40px;" align="center">
              <p style="margin:0; font-size:11px; color:#94a3b8;">
                This is an automated message from Citizen Link. For support, contact
                <a href="mailto:support@citizenlink.app" style="color:#006397; text-decoration:none;">support@citizenlink.app</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
