<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Delivery Attempt Unsuccessful — Citizen Link</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f6f9; font-family:'Inter', Arial, sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- Header -->
          <tr>
            <td align="center" style="background-color:#003b5a; border-radius:12px 12px 0 0; padding:28px 40px;">
              <p style="margin:0; font-size:22px; font-weight:700; color:#ffffff; letter-spacing:-0.3px;">Citizen Link</p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color:#ffffff; padding:40px; border-left:1px solid #e2e8f0; border-right:1px solid #e2e8f0;">
              <p style="margin:0 0 20px; font-size:22px; font-weight:700; color:#003b5a; line-height:1.3;">
                Delivery Attempt Was Unsuccessful
              </p>
              <p style="margin:0 0 16px; font-size:15px; color:#475569; line-height:1.7;">
                We were unable to deliver your <strong>{{exchange.document.type.name}}</strong>
                (claim <strong>#{{exchange.claim.claimNumber}}</strong>).
              </p>

              <!-- Reason box -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#fef2f2; border-left:4px solid #ef4444; border-radius:0 8px 8px 0; margin-bottom:24px;">
                <tr>
                  <td style="padding:14px 16px;">
                    <p style="margin:0 0 4px; font-size:11px; font-weight:700; color:#b91c1c; text-transform:uppercase; letter-spacing:0.8px;">Reason</p>
                    <p style="margin:0; font-size:14px; color:#7f1d1d; line-height:1.6;">{{exchange.reason}}</p>
                  </td>
                </tr>
              </table>

              {{#if exchange.isMaxReached}}
              <!-- Max attempts reached -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#fff7ed; border:1.5px solid #f59e0b; border-radius:10px; margin-bottom:28px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <p style="margin:0 0 8px; font-size:13px; font-weight:700; color:#b45309; text-transform:uppercase; letter-spacing:0.5px;">Action Required — Collect In Person</p>
                    <p style="margin:0; font-size:14px; color:#78350f; line-height:1.7;">
                      You have reached the maximum number of courier delivery attempts. Your document is safe at a
                      Citizen Link station. Please visit a station to collect it in person. Select <strong>Owner Pickup</strong>
                      when rescheduling your handover.
                    </p>
                  </td>
                </tr>
              </table>
              {{else}}
              <!-- Retry available -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#f0f9ff; border:1.5px solid #006397; border-radius:10px; margin-bottom:28px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <p style="margin:0 0 8px; font-size:13px; font-weight:700; color:#006397; text-transform:uppercase; letter-spacing:0.5px;">You Have {{exchange.attemptsLeft}} Attempt(s) Remaining</p>
                    <p style="margin:0; font-size:14px; color:#0c4a6e; line-height:1.7;">
                      You may reschedule a new courier delivery. Please ensure your address is accurate
                      and that you will be available at the scheduled time to avoid further failed attempts.
                      After {{exchange.attemptsLeft}} more failed attempt(s), you will be required to collect in person.
                    </p>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Delivery policy reminder -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; margin-bottom:28px;">
                <tr>
                  <td style="padding:16px 20px;">
                    <p style="margin:0 0 6px; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px;">Delivery Policy Reminder</p>
                    <ul style="margin:0; padding:0 0 0 18px; font-size:13px; color:#475569; line-height:1.8;">
                      <li>Delivery fees are non-refundable once a courier has been dispatched.</li>
                      <li>Ensure someone is available at the delivery address at the scheduled time.</li>
                      <li>After the maximum number of failed attempts, in-person collection is required.</li>
                    </ul>
                  </td>
                </tr>
              </table>

              <!-- CTA -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 32px;">
                <tr>
                  <td align="center" style="border-radius:8px; background-color:#003b5a;">
                    <a href="citizenlinkapp://document-case/{{exchange.claim.id}}"
                      style="display:inline-block; padding:14px 32px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px;">
                      Reschedule Handover →
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:0; font-size:14px; color:#475569; line-height:1.7;">
                We apologise for the inconvenience and appreciate your patience.<br />
                <strong style="color:#003b5a;">The Citizen Link Team</strong>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8fafc; border:1px solid #e2e8f0; border-top:none; border-radius:0 0 12px 12px; padding:20px 40px;" align="center">
              <p style="margin:0; font-size:11px; color:#94a3b8;">
                This is an automated message from Citizen Link. For support, contact
                <a href="mailto:support@citizenlink.app" style="color:#006397; text-decoration:none;">support@citizenlink.app</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
