<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Match Found — Citizen Link</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f6f9; font-family:'Inter', Arial, sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- Header -->
          <tr>
            <td align="center" style="background-color:#003b5a; border-radius:12px 12px 0 0; padding:28px 40px;">
              <p style="margin:0; font-size:22px; font-weight:700; color:#ffffff; letter-spacing:-0.3px;">Citizen Link</p>
              <p style="margin:6px 0 0; font-size:12px; color:#a8cfe0; letter-spacing:0.8px; text-transform:uppercase;">Trusted Civic Services</p>
            </td>
          </tr>

          <!-- Gold accent bar -->
          <tr>
            <td style="background-color:#e8b84b; padding:10px 40px;">
              <p style="margin:0; font-size:13px; font-weight:600; color:#003b5a; text-align:center; letter-spacing:0.3px;">
                Great news — a potential match has been found
              </p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color:#ffffff; padding:40px; border-left:1px solid #e2e8f0; border-right:1px solid #e2e8f0;">

              <h1 style="margin:0 0 16px; font-size:22px; font-weight:700; color:#003b5a; line-height:1.3;">
                Is this your document?
              </h1>
              <p style="margin:0 0 24px; font-size:15px; color:#475569; line-height:1.7;">
                Our matching engine has identified a strong potential match for your lost <strong>{{match.lostDocumentCase.case.document.type.name}}</strong>. Please review the match details and let us know whether this document belongs to you.
              </p>

              <!-- Match summary -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#f0f7ff; border:1px solid #bfdbfe; border-radius:10px; margin-bottom:24px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <p style="margin:0 0 12px; font-size:11px; font-weight:600; color:#006397; letter-spacing:0.8px; text-transform:uppercase;">Match Details</p>
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="padding:5px 0; font-size:13px; color:#64748b; width:40%;">Match Reference</td>
                        <td style="padding:5px 0; font-size:13px; font-weight:600; color:#0f172a;">#{{match.matchNumber}}</td>
                      </tr>
                      <tr>
                        <td style="padding:5px 0; font-size:13px; color:#64748b;">Document Type</td>
                        <td style="padding:5px 0; font-size:13px; font-weight:600; color:#0f172a;">{{match.lostDocumentCase.case.document.type.name}}</td>
                      </tr>
                      <tr>
                        <td style="padding:5px 0; font-size:13px; color:#64748b;">Lost Case</td>
                        <td style="padding:5px 0; font-size:13px; font-weight:600; color:#0f172a;">#{{match.lostDocumentCase.case.caseNumber}}</td>
                      </tr>
                      <tr>
                        <td style="padding:5px 0; font-size:13px; color:#64748b;">Found Case</td>
                        <td style="padding:5px 0; font-size:13px; font-weight:600; color:#0f172a;">#{{match.foundDocumentCase.case.caseNumber}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Action note -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#fffbeb; border-left:4px solid #e8b84b; border-radius:0 8px 8px 0; margin-bottom:32px;">
                <tr>
                  <td style="padding:14px 18px;">
                    <p style="margin:0; font-size:13px; color:#78350f; line-height:1.6;">
                      <strong>Your response matters.</strong> Open the match in the app to review the full details — including document images — then confirm or decline. Unclaimed matches expire after a set period.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Primary CTA — View details -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 12px; width:100%;">
                <tr>
                  <td align="center" style="border-radius:8px; background-color:#003b5a;">
                    <a href="https://citizenlink.app/matches/{{match.id}}"
                      style="display:block; padding:14px 32px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px; text-align:center;">
                      View Match Details →
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Secondary CTAs — Claim / Reject -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 12px; width:100%;">
                <tr>
                  <td style="width:50%; padding-right:6px;">
                    <a href="https://citizenlink.app/matches/{{match.id}}/claim"
                      style="display:block; padding:12px 16px; font-size:14px; font-weight:600; color:#1d9e75; text-decoration:none; border-radius:8px; text-align:center; border:1.5px solid #1d9e75;">
                      ✓ Yes, This Is Mine
                    </a>
                  </td>
                  <td style="width:50%; padding-left:6px;">
                    <a href="https://citizenlink.app/matches/{{match.id}}/reject"
                      style="display:block; padding:12px 16px; font-size:14px; font-weight:600; color:#94a3b8; text-decoration:none; border-radius:8px; text-align:center; border:1.5px solid #e2e8f0;">
                      ✗ Not My Document
                    </a>
                  </td>
                </tr>
              </table>
              <p style="margin:0 0 28px; font-size:11px; color:#94a3b8; text-align:center;">
                We recommend reviewing the full match details before responding.
              </p>

              <p style="margin:0 0 4px; font-size:14px; color:#475569; line-height:1.7;">
                Thank you for using Citizen Link. We are committed to reuniting lost documents with their rightful owners as quickly as possible.
              </p>
              <p style="margin:0; font-size:14px; color:#475569;">
                Best regards,<br />
                <strong style="color:#003b5a;">The Citizen Link Team</strong>
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8fafc; border:1px solid #e2e8f0; border-top:none; border-radius:0 0 12px 12px; padding:20px 40px;" align="center">
              <p style="margin:0 0 8px; font-size:11px; color:#94a3b8;">
                If the buttons above do not work, copy and paste one of these links into your browser:
              </p>
              <p style="margin:0 0 4px; font-size:11px; color:#64748b; word-break:break-all;">
                View: https://citizenlink.app/matches/{{match.id}}
              </p>
              <p style="margin:0 0 4px; font-size:11px; color:#64748b; word-break:break-all;">
                Claim: https://citizenlink.app/matches/{{match.id}}/claim
              </p>
              <p style="margin:0 0 12px; font-size:11px; color:#64748b; word-break:break-all;">
                Decline: https://citizenlink.app/matches/{{match.id}}/reject
              </p>
              <p style="margin:0; font-size:11px; color:#94a3b8;">
                This is an automated message from Citizen Link. For support, contact
                <a href="mailto:support@citizenlink.app" style="color:#006397; text-decoration:none;">support@citizenlink.app</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
