<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Match Found — Citizen Link</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f6f9; font-family:'Inter', Arial, sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- Header with gold accent -->
          <tr>
            <td align="center" style="background-color:#003b5a; border-radius:12px 12px 0 0; padding:28px 40px;">
              <p style="margin:0; font-size:22px; font-weight:700; color:#ffffff; letter-spacing:-0.3px;">Citizen Link</p>
              <p style="margin:6px 0 0; font-size:12px; color:#a8cfe0; letter-spacing:0.8px; text-transform:uppercase;">Trusted Civic Services</p>
            </td>
          </tr>
          <tr>
            <td style="background-color:#e8b84b; padding:12px 40px;">
              <p style="margin:0; font-size:13px; font-weight:700; color:#78350f; text-align:center; letter-spacing:0.3px;">
                POTENTIAL MATCH FOUND — YOUR ACTION IS REQUIRED
              </p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color:#ffffff; padding:40px; border-left:1px solid #e2e8f0; border-right:1px solid #e2e8f0;">
              <h1 style="margin:0 0 12px; font-size:24px; font-weight:700; color:#003b5a; line-height:1.3;">
                Is This Your Document?
              </h1>
              <p style="margin:0 0 24px; font-size:15px; color:#475569; line-height:1.7;">
                Our system has found a potential match for your lost <strong>{{match.lostDocumentCase.case.document.type.name}}</strong> (case #{{match.lostDocumentCase.case.caseNumber}}). Please review the match details and let us know whether this document belongs to you.
              </p>

              <!-- Match summary card -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; margin-bottom:28px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <p style="margin:0 0 12px; font-size:11px; font-weight:600; color:#006397; letter-spacing:0.8px; text-transform:uppercase;">Match Details</p>
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="padding:4px 0; font-size:13px; color:#64748b; width:40%;">Match Reference</td>
                        <td style="padding:4px 0; font-size:13px; font-weight:600; color:#0f172a;">#{{match.matchNumber}}</td>
                      </tr>
                      <tr>
                        <td style="padding:4px 0; font-size:13px; color:#64748b;">Document Type</td>
                        <td style="padding:4px 0; font-size:13px; font-weight:600; color:#0f172a;">{{match.lostDocumentCase.case.document.type.name}}</td>
                      </tr>
                      <tr>
                        <td style="padding:4px 0; font-size:13px; color:#64748b;">Your Lost Case</td>
                        <td style="padding:4px 0; font-size:13px; font-weight:600; color:#0f172a;">#{{match.lostDocumentCase.case.caseNumber}}</td>
                      </tr>
                      <tr>
                        <td style="padding:4px 0; font-size:13px; color:#64748b;">Found Case Matched</td>
                        <td style="padding:4px 0; font-size:13px; font-weight:600; color:#0f172a;">#{{match.foundDocumentCase.case.caseNumber}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Primary CTA -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 20px;">
                <tr>
                  <td align="center" style="border-radius:8px; background-color:#003b5a;">
                    <a href="citizenlinkapp://match/{{match.id}}"
                      style="display:inline-block; padding:14px 36px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px; letter-spacing:-0.1px;">
                      View Full Match Details →
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Claim / Reject side-by-side -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:28px;">
                <tr>
                  <td width="48%" align="center">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="width:100%;">
                      <tr>
                        <td align="center" style="border-radius:8px; background-color:#1d9e75;">
                          <a href="citizenlinkapp://match/{{match.id}}/claim"
                            style="display:block; padding:12px 16px; font-size:14px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px; text-align:center;">
                            ✓ Yes, This Is Mine
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td width="4%"></td>
                  <td width="48%" align="center">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="width:100%;">
                      <tr>
                        <td align="center" style="border-radius:8px; background-color:#ffffff; border:2px solid #e2e8f0;">
                          <a href="citizenlinkapp://match/{{match.id}}/reject"
                            style="display:block; padding:10px 16px; font-size:14px; font-weight:600; color:#64748b; text-decoration:none; border-radius:6px; text-align:center;">
                            ✗ Not My Document
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Info note -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#fffbeb; border-left:4px solid #e8b84b; border-radius:0 8px 8px 0; margin-bottom:32px;">
                <tr>
                  <td style="padding:14px 18px;">
                    <p style="margin:0; font-size:13px; color:#78350f; line-height:1.7;">
                      <strong>Why is your response important?</strong><br />
                      Confirming or rejecting a match helps us process document returns faster and keeps the matching system accurate for everyone.
                    </p>
                  </td>
                </tr>
              </table>

              <p style="margin:0; font-size:14px; color:#475569; line-height:1.7;">
                If you have any questions, our support team is here to help.<br />
                <strong style="color:#003b5a;">The Citizen Link Team</strong>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8fafc; border:1px solid #e2e8f0; border-top:none; border-radius:0 0 12px 12px; padding:20px 40px;" align="center">
              <p style="margin:0 0 12px; font-size:11px; color:#94a3b8;">
                If the buttons above do not open the app, open Citizen Link and go to <strong>My Cases → Match #{{match.matchNumber}}</strong> to review and respond.
              </p>
              <p style="margin:0; font-size:11px; color:#94a3b8;">
                This is an automated message from Citizen Link. For support, contact
                <a href="mailto:support@citizenlink.app" style="color:#006397; text-decoration:none;">support@citizenlink.app</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
