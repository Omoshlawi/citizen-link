<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Email address change requested — Citizen Link</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f6f9;font-family:'Inter',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f4f6f9;padding:40px 16px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background-color:#003b5a;padding:36px 40px;text-align:center;">
              <p style="margin:0;font-family:'Plus Jakarta Sans','Inter',Arial,sans-serif;font-size:26px;font-weight:700;color:#ffffff;letter-spacing:-0.5px;">Citizen Link</p>
              <p style="margin:8px 0 0;font-size:13px;color:#a8c8da;letter-spacing:1px;text-transform:uppercase;">Civic Services Platform</p>
            </td>
          </tr>

          <!-- Amber security accent bar -->
          <tr>
            <td style="background-color:#e8b84b;height:4px;"></td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:48px 40px 32px;">
              <h1 style="margin:0 0 8px;font-family:'Plus Jakarta Sans','Inter',Arial,sans-serif;font-size:24px;font-weight:700;color:#003b5a;">Hello, {{user.name}}!</h1>
              <p style="margin:0 0 24px;font-size:15px;color:#4a5568;line-height:1.7;">
                We're letting you know that a request was made to change the email address on your <strong>Citizen Link</strong> account.
              </p>

              <!-- Details box -->
              <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:32px;">
                <tr>
                  <td style="background-color:#fffbeb;border-left:4px solid #e8b84b;border-radius:0 6px 6px 0;padding:16px 20px;">
                    <p style="margin:0 0 8px;font-size:13px;color:#2d4a5e;line-height:1.6;">
                      <strong>Current email:</strong> {{user.email}}<br/>
                      <strong>Requested new email:</strong> {{newEmail}}
                    </p>
                    <p style="margin:0;font-size:13px;color:#4a5568;line-height:1.6;">
                      A verification link has been sent to the new address. The change will take effect once it is confirmed.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Security warning box -->
              <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom:32px;">
                <tr>
                  <td style="background-color:#fff5f5;border-left:4px solid #e53e3e;border-radius:0 6px 6px 0;padding:16px 20px;">
                    <p style="margin:0;font-size:13px;color:#742a2a;line-height:1.6;">
                      <strong>Wasn't you?</strong> If you did not make this request, your account may be compromised. Please contact us immediately at <a href="mailto:support@citizenlink.app" style="color:#c53030;text-decoration:underline;">support@citizenlink.app</a> so we can secure your account.
                    </p>
                  </td>
                </tr>
              </table>

              <p style="margin:0;font-size:13px;color:#718096;line-height:1.6;">
                If this was you, no further action is needed on this address — simply verify the new email to complete the change.
              </p>
            </td>
          </tr>

          <!-- Divider -->
          <tr>
            <td style="padding:0 40px;">
              <hr style="border:none;border-top:1px solid #edf2f7;margin:0;" />
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px 40px 36px;">
              <p style="margin:0 0 4px;font-size:13px;color:#4a5568;line-height:1.6;">
                Need help? Contact us at <a href="mailto:support@citizenlink.app" style="color:#006397;text-decoration:none;">support@citizenlink.app</a>
              </p>
              <p style="margin:0;font-size:12px;color:#a0aec0;line-height:1.6;">
                &copy; {{year}} Citizen Link. All rights reserved.<br/>
                This is an automated message — please do not reply directly to this email.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
