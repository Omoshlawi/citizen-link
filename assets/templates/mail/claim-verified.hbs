<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Claim Approved — Pay to Collect Your Document</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f6f9; font-family:'Inter', Arial, sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:600px;">

          <!-- Header -->
          <tr>
            <td align="center" style="background-color:#003b5a; border-radius:12px 12px 0 0; padding:28px 40px;">
              <p style="margin:0; font-size:22px; font-weight:700; color:#ffffff; letter-spacing:-0.3px;">Citizen Link</p>
              <p style="margin:6px 0 0; font-size:12px; color:#a8cfe0; letter-spacing:0.8px; text-transform:uppercase;">Trusted Civic Services</p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color:#ffffff; padding:40px; border-left:1px solid #e2e8f0; border-right:1px solid #e2e8f0;">
              <p style="margin:0 0 8px; font-size:15px; color:#475569;">Hello,</p>
              <h1 style="margin:0 0 20px; font-size:22px; font-weight:700; color:#003b5a; line-height:1.3;">
                Your Claim Is Approved — One Step Left
              </h1>
              <p style="margin:0 0 24px; font-size:15px; color:#475569; line-height:1.7;">
                Great news! Your claim for <strong>{{document.type.name}}</strong> (claim #{{claim.claimNumber}}) has been reviewed and approved. To proceed with collecting your document, please complete the payment below.
              </p>

              <!-- Claim card -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; margin-bottom:24px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <p style="margin:0 0 10px; font-size:11px; font-weight:600; color:#1d9e75; letter-spacing:0.8px; text-transform:uppercase;">Claim Approved</p>
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="padding:4px 0; font-size:13px; color:#64748b; width:40%;">Claim Number</td>
                        <td style="padding:4px 0; font-size:13px; font-weight:600; color:#0f172a;">#{{claim.claimNumber}}</td>
                      </tr>
                      <tr>
                        <td style="padding:4px 0; font-size:13px; color:#64748b;">Document Type</td>
                        <td style="padding:4px 0; font-size:13px; font-weight:600; color:#0f172a;">{{document.type.name}}</td>
                      </tr>
                      <tr>
                        <td style="padding:4px 0; font-size:13px; color:#64748b;">Amount Due</td>
                        <td style="padding:4px 0; font-size:15px; font-weight:700; color:#003b5a;">{{currency invoice.totalAmount}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Payment info panel -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#eff6ff; border-left:4px solid #006397; border-radius:0 8px 8px 0; margin-bottom:32px;">
                <tr>
                  <td style="padding:16px 18px;">
                    <p style="margin:0 0 6px; font-size:13px; font-weight:600; color:#1e3a5f;">How to pay</p>
                    <p style="margin:0; font-size:13px; color:#1e3a5f; line-height:1.7;">
                      Open the Citizen Link app and navigate to your claim. Tap <strong>Pay with M-Pesa</strong> to receive a payment prompt on your phone. Once payment is confirmed, you can schedule collection of your document.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- CTA -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 32px;">
                <tr>
                  <td align="center" style="border-radius:8px; background-color:#1d9e75;">
                    <a href="citizenlinkapp://claims/{{claim.id}}"
                      style="display:inline-block; padding:14px 32px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px; letter-spacing:-0.1px;">
                      Pay &amp; Arrange Collection →
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Finder reward note -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background-color:#fefce8; border-left:4px solid #e8b84b; border-radius:0 8px 8px 0; margin-bottom:32px;">
                <tr>
                  <td style="padding:14px 18px;">
                    <p style="margin:0; font-size:13px; color:#78350f; line-height:1.7;">
                      Part of this fee goes directly to the finder who safeguarded your document, ensuring a sustainable community of integrity and trust.
                    </p>
                  </td>
                </tr>
              </table>

              <p style="margin:0; font-size:14px; color:#475569; line-height:1.7;">
                If you have any questions, please contact our support team.<br />
                <strong style="color:#003b5a;">The Citizen Link Team</strong>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8fafc; border:1px solid #e2e8f0; border-top:none; border-radius:0 0 12px 12px; padding:20px 40px;" align="center">
              <p style="margin:0 0 12px; font-size:11px; color:#94a3b8;">
                If the button above does not open the app, open Citizen Link and go to <strong>Claims → #{{claim.claimNumber}}</strong>.
              </p>
              <p style="margin:0; font-size:11px; color:#94a3b8;">
                This is an automated message from Citizen Link. For support, contact
                <a href="mailto:support@citizenlink.app" style="color:#006397; text-decoration:none;">support@citizenlink.app</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
