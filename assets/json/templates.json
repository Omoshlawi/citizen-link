[
  {
    "key": "notification.case.lost.reported",
    "type": "notification",
    "name": "Lost Case Reported",
    "description": "Sent to owner when they report a lost document.",
    "engine": "handlebars",
    "slots": {
      "email_subject": { "source": "text", "text": "Lost Document Case #{{case.caseNumber}} Reported" },
      "email_body": { "source": "file", "path": "mail/document-case-reported.hbs" },
      "sms_body": { "source": "text", "text": "Citizen Link: Your lost document case #{{case.caseNumber}} ({{case.document.type.name}}) has been reported. We are now searching for matches." },
      "push_title": { "source": "text", "text": "Report Received #{{case.caseNumber}}" },
      "push_body": { "source": "text", "text": "We are searching for matches for your {{case.document.type.name}} case." }
    },
    "schema": { "required": [], "optional": ["email_subject", "email_body", "sms_body", "push_title", "push_body"] },
    "metadata": { "channels": { "email": true, "sms": true, "push": true } }
  },
  {
    "key": "notification.case.found.verified",
    "type": "notification",
    "name": "Found Case Verified",
    "description": "Sent to finder when their found report is verified by staff.",
    "engine": "handlebars",
    "slots": {
      "email_subject": { "source": "text", "text": "Found Document Case #{{case.caseNumber}} Verified" },
      "email_body": { "source": "file", "path": "mail/document-case-reported.hbs" },
      "sms_body": { "source": "text", "text": "Citizen Link: Your found document case #{{case.caseNumber}} ({{case.document.type.name}}) has been verified. We are now matching it with lost cases." },
      "push_title": { "source": "text", "text": "Report Verified #{{case.caseNumber}}" },
      "push_body": { "source": "text", "text": "Your report for {{case.document.type.name}} has been verified." }
    },
    "schema": { "required": [], "optional": ["email_subject", "email_body", "sms_body", "push_title", "push_body"] },
    "metadata": { "channels": { "email": true, "sms": true, "push": true } }
  },
  {
    "key": "notification.case.found.matched",
    "type": "notification",
    "name": "Lost Owner Match Found",
    "description": "Sent to the owner of a lost document when a match is found.",
    "engine": "handlebars",
    "slots": {
      "email_subject": { "source": "text", "text": "Match Found! Case #{{match.lostDocumentCase.case.caseNumber}}" },
      "email_body": { "source": "file", "path": "mail/document-match-found.hbs" },
      "sms_body": { "source": "text", "text": "Citizen Link: Match found for your lost case #{{match.lostDocumentCase.case.caseNumber}} ({{match.lostDocumentCase.case.document.type.name}}). Visit citizenlink.app to see details." },
      "push_title": { "source": "text", "text": "Match Found! #{{match.lostDocumentCase.case.caseNumber}}" },
      "push_body": { "source": "text", "text": "A potential match for your {{match.lostDocumentCase.case.document.type.name}} has been located." }
    },
    "schema": { "required": [], "optional": ["email_subject", "email_body", "sms_body", "push_title", "push_body"] },
    "metadata": { "channels": { "email": true, "sms": true, "push": true } }
  },
  {
    "key": "notification.case.lost.matched",
    "type": "notification",
    "name": "Found Finder Match Found",
    "description": "Sent to the finder of a document when a match is found with a lost case.",
    "engine": "handlebars",
    "slots": {
      "email_subject": { "source": "text", "text": "Match Found for Case #{{match.foundDocumentCase.case.caseNumber}}" },
      "email_body": { "source": "file", "path": "mail/document-match-found.hbs" },
      "sms_body": { "source": "text", "text": "Citizen Link: Match found for found case #{{match.foundDocumentCase.case.caseNumber}} ({{match.foundDocumentCase.case.document.type.name}}). Visit citizenlink.app to see details." },
      "push_title": { "source": "text", "text": "Match Found! #{{match.foundDocumentCase.case.caseNumber}}" },
      "push_body": { "source": "text", "text": "A potential match for the {{match.foundDocumentCase.case.document.type.name}} you found has been located." }
    },
    "schema": { "required": [], "optional": ["email_subject", "email_body", "sms_body", "push_title", "push_body"] },
    "metadata": { "channels": { "email": true, "sms": true, "push": true } }
  },
