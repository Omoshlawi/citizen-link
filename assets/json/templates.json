      },
      "push_title": {
        "source": "text",
        "text": "Report Verified \u2014 #{{case.caseNumber}}"
      },
      "push_body": {
        "source": "text",
        "text": "Your found {{case.document.type.name}} report has been verified. We are now searching for the rightful owner."
      },
      "push_data": {
        "source": "text",
        "text": "{\"screen\": \"document-case\", \"caseId\": \"{{case.id}}\"}"
