      },
      "email_body": {
        "source": "file",
        "path": "mail/claim-verified.hbs"
      },
      "sms_body": {
        "source": "text",
        "text": "Citizen Link: Your claim #{{claim.claimNumber}} for {{document.type.name}} is approved. Open the app to complete payment and arrange collection."
