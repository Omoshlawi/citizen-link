[
  {
    "key": "notification.case.lost.reported",
    "type": "notification",
    "name": "Lost Case Reported",
    "description": "Sent to the owner when they submit a lost document report.",
    "engine": "handlebars",
    "slots": {
      "email_subject": {
        "source": "text",
        "text": "Lost Document Case #{{case.caseNumber}} Received \u2014 Citizen Link"
      },
      "email_body": {
        "source": "file",
        "path": "mail/lost-case-reported.hbs"
      },
      "sms_body": {
        "source": "text",
        "text": "Citizen Link: Your lost {{case.document.type.name}} case #{{case.caseNumber}} has been registered. We will notify you when a match is found."
      },
      "push_title": {
        "source": "text",
        "text": "Report Received \u2014 #{{case.caseNumber}}"
      },
      "push_body": {
        "source": "text",
        "text": "Your lost {{case.document.type.name}} report has been registered. We are now searching for a match."
      }
    },
    "schema": {
      "required": [],
      "optional": [
        "email_subject",
        "email_body",
        "sms_body",
        "push_title",
        "push_body"
      ]
    },
    "metadata": {
      "channels": {
        "email": true,
        "sms": true,
        "push": true
      }
    }
  },
  {
    "key": "notification.case.found.submitted",
    "type": "notification",
    "name": "Found Case Submitted",
    "description": "Sent to the finder when their found document report is submitted and awaiting staff review.",
    "engine": "handlebars",
    "slots": {
      "push_title": {
        "source": "text",
        "text": "Report Submitted \u2014 Under Review"
      },
      "push_body": {
        "source": "text",
        "text": "Your found {{case.document.type.name}} report (case #{{case.caseNumber}}) has been submitted and is awaiting verification."
      },
      "push_data": {
        "source": "text",
        "text": "{\"screen\": \"document-case\", \"caseId\": \"{{case.id}}\"}"
      }
    },
    "schema": {
      "required": [],
      "optional": [
        "push_title",
        "push_body",
        "push_data"
      ]
    },
    "metadata": {
      "channels": {
        "email": false,
        "sms": false,
        "push": true
      }
    }
  },
  {
    "key": "notification.case.found.verified",
