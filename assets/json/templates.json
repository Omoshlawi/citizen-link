  {
    "key": "notification.case.found.matched",
    "type": "notification",
    "name": "Owner Match Found",
    "description": "Sent to the owner of a lost document when a matching found report is identified. Owner must claim or reject.",
    "engine": "handlebars",
    "slots": {
      "email_subject": {
        "source": "text",
        "text": "Match Found for Your Lost Case #{{match.lostDocumentCase.case.caseNumber}} \u2014 Action Required"
      },
      "email_body": {
        "source": "file",
        "path": "mail/owner-match-found.hbs"
      },
      "sms_body": {
        "source": "text",
        "text": "Citizen Link: A match was found for your lost {{match.lostDocumentCase.case.document.type.name}} (case #{{match.lostDocumentCase.case.caseNumber}}). Open the app to claim or reject the match."
      },
      "push_title": {
        "source": "text",
        "text": "Match Found \u2014 Is This Yours?"
      },
      "push_body": {
        "source": "text",
        "text": "A potential match was found for your {{match.lostDocumentCase.case.document.type.name}} (case #{{match.lostDocumentCase.case.caseNumber}}). Tap to review and respond."
      },
      "push_data": {
        "source": "text",
        "text": "{\"screen\": \"match\", \"matchId\": \"{{match.id}}\"}"
      }
    },
    "schema": {
      "required": [],
      "optional": [
        "email_subject",
        "email_body",
        "sms_body",
        "push_title",
        "push_body",
        "push_data"
      ]
    },
    "metadata": {
      "channels": {
        "email": true,
        "sms": true,
        "push": true
      }
    }
  },
