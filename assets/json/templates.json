      },
      "push_body": {
        "source": "text",
        "text": "Your claim #{{claim.claimNumber}} is approved. Complete payment to arrange collection of your {{document.type.name}}."
      },
      "push_data": {
        "source": "text",
        "text": "{\"screen\":\"claim\",\"claimId\":\"{{claim.id}}\"}"
      }
    },
    "schema": {
      "required": [],
