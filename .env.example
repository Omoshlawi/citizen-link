REDIS_USERNAME=username
REDIS_PASSWORD=password
REDIS_DB_URL=redis://username:password@redis:6379

# Database credentials for Docker Compose (PostgreSQL standard vars)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=citizen-link
DATABASE_URL=postgresql://user:password@db:5432/citizen-link


# Application Configuration
PORT=2000
NODE_ENV=development
BETTER_AUTH_URL="http://localhost:2000"
BETTER_AUTH_SECRET=your-secret-key-here-generate-a-random-string

# MinIO Configuration (for S3-like storage)
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=Admin123

S3_ACCESS_KEY_ID=root
S3_SECRETE_ACCESS_KEY_ID=Admin123
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_TMP=cl-tmp
S3_BUCKET_CASES=cl-cases
S3_MAX_FILE_SIZE=10485760 # 10 MB

# Admin User Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123
ADMIN_EMAIL=admin@citizenlink.app
SKIP_ADMIN_IF_EXISTS=true

# AI Configuration
# Uncomment and configure based on your AI provider

# -------- Ollama (Local AI) -------
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434
VISION_AI_BASE_URL=http://localhost:11434
VISION_AI_API_KEY=ollama
VISION_AI_MODEL=gemma4
OPENAI_MODEL=gemma4

# -------- OpenAI -------
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com
# VISION_AI_BASE_URL=https://api.openai.com
# VISION_AI_API_KEY=sk-your-openai-api-key
# VISION_AI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-4o

TEXT_EXTRACTION_AI_BASE_URL=https://api.openai.com
TEXT_EXTRACTION_AI_API_KEY=sk-your-openai-api-key
TEXT_EXTRACTION_AI_MODEL=gpt-4o-mini

EMBEDDING_IS_OPENAI=true
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com
EMBEDDING_API_KEY=sk-your-openai-api-key

# SMTP / Email Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
# Required in production (no default):
# SMTP_FROM=CitizenLink <no-reply@yourdomain.com>

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token

# -------- DeepSeek -------
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# -------- Gemini -------
# OPENAI_API_KEY=your-gemini-api-key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.0-flash-exp

# M-Pesa / Daraja (Safaricom) Payment Integration
DARAJA_ENV=sandbox                          # sandbox | production
DARAJA_CONSUMER_KEY=your-consumer-key
DARAJA_CONSUMER_SECRET=your-consumer-secret
DARAJA_SHORTCODE=174379                     # Sandbox till: 174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919  # Sandbox passkey
DARAJA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/transaction/callback/daraja

# M-Pesa B2C (Business-to-Customer) — used for disbursing finder rewards
# Download real Safaricom certs from the Daraja portal and place at assets/certs/
DARAJA_B2C_INITIATOR_NAME=testapi
DARAJA_B2C_INITIATOR_PASSWORD=Safaricom999!*!
DARAJA_B2C_RESULT_URL=https://your-ngrok-url.ngrok.io/api/disbursement/callback/daraja-b2c
DARAJA_B2C_TIMEOUT_URL=https://your-ngrok-url.ngrok.io/api/disbursement/callback/daraja-b2c


# Web portal
FRONTEND_URL=http://localhost:5173

# Regional Configuration — one deployment per government
# All values have Kenya defaults; override for other regions.
REGION_COUNTRY_CODE=KE                   # ISO 3166-1 alpha-2
REGION_COUNTRY_NAME=Kenya
REGION_CURRENCY=KES                      # ISO 4217 — validated at startup
REGION_LOCALE=en-KE                      # BCP 47 — used for Intl.* formatting
REGION_TIMEZONE=Africa/Nairobi           # IANA timezone — validated at startup
REGION_LANGUAGES=en,sw                   # Comma-separated BCP 47 codes
REGION_CALLING_CODE=+254                 # E.164 country calling code
REGION_PHONE_REGEX=^(\+?254|0)((7|1)\d{8})$   # Full phone validation regex
REGION_SUBSCRIBER_REGEX=^[71]\d{8}$     # Subscriber-only digits (after calling code)
REGION_SUBSCRIBER_EXAMPLE=712 345 678   # Shown as placeholder hint in forms
REGION_MAP_LAT=-1.2921                  # Default map center latitude
REGION_MAP_LNG=36.8219                  # Default map center longitude
REGION_ADDRESS_LOCALE_CODE=ke-default   # Must match seeded AddressLocale.code
REGION_PAYMENT_PROVIDERS=mpesa          # Comma-separated provider names
REGION_APP_NAME=CitizenLink Kenya       # Deployment branding

# ── CitizenLink AI Service ──────────────────────────────────────────────────
# The AI chatbot microservice runs independently on its own server.
# Set AI_SERVICE_URL to that server's address (IP or domain + port 8001).
# Both values must match what is configured in the AI service's .env.
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_INTERNAL_SECRET=generate-with-openssl-rand-hex-32